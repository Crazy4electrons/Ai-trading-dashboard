# MT5 Python Bridge Server Configuration

# FastAPI Server
API_PORT=3002
API_HOST=127.0.0.1
LOG_LEVEL=DEBUG

# WebSocket Connection to Node Backend
NODE_WS_URL=ws://127.0.0.1:3001/api/mt5/ws-internal
NODE_API_TOKEN=your_shared_token_secret_here_min_32_chars

# MT5 Connection (will be provided via CLI args, but can be set here as defaults)
# Format: --account <int> --password <str> --server <str>
# Examples:
# MT5_ACCOUNT=123456
# MT5_PASSWORD=password
# MT5_SERVER=MetaQuotes-Demo

# Trade Detection
POSITION_POLL_INTERVAL_SECONDS=5
RECONNECT_MAX_RETRIES=10
RECONNECT_BASE_DELAY_SECONDS=1
RECONNECT_MAX_DELAY_SECONDS=30
