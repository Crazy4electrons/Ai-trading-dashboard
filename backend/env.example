# JWT Authentication
JWT_SECRET=your_jwt_secret_key_min_32_chars_long_secure_random_string

# MT5 Terminal Connection (via Python bridge server)
MT5_ACCOUNT=your_mt5_account_number_here
MT5_PASSWORD=your_mt5_terminal_password_here
MT5_SERVER=MetaQuotes-Demo

# MT5 Python Bridge Server Configuration
PYTHON_MT5_PORT=3002
PYTHON_MT5_TOKEN_SECRET=your_shared_token_secret_here_min_32_chars
PYTHON_PATH=python  # or full path to Python executable
ENCRYPTION_KEY=your_encryption_key_min_32_chars_base64_encoded

# News API
NEWS_API_KEY=your_newsapi_key_here

# LLM Providers (optional if not using AI analysis)
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Server
PORT=3001
